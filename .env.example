# PostgreSQL connection string used by Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/speedcubing?schema=public

# JWT secrets (use long random strings in production)
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# WCA OAuth application credentials
# Register an app at https://www.worldcubeassociation.org/oauth/applications
WCA_CLIENT_ID=
WCA_CLIENT_SECRET=
WCA_REDIRECT_URI=http://localhost:3001/api/auth/wca/callback

# Frontend origin (used for CORS + OAuth redirects back to the SPA)
FRONTEND_URL=http://localhost:5173

# Server port
PORT=3001

# Optional Redis URL for WCA cache. If omitted, an in-memory cache is used.
REDIS_URL=
